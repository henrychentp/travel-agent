{
  "name": "travel-agent",
  "version": "0.1.0",
  "description": "Hermes: one travel agent coordinating three specialist workstreams (onboarding, whole-trip planner, in-trip concierge) over shared Mem0 taste and Trip State.",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "tsc && node --test \"dist/tests/**/*.test.js\"",
    "start": "tsc && node --env-file=.env dist/src/skills/onboarding/dev.js",
    "telegram": "tsc && node --env-file=.env dist/src/surfaces/telegram/server.js",
    "dev:telegram": "bash scripts/dev-telegram.sh",
    "demo": "bash scripts/run-demo.sh",
    "tunnel:cf": "bash scripts/start-tunnel.sh",
    "tunnel": "ngrok http 8787",
    "check-secrets": "node scripts/check-secrets.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  }
}
