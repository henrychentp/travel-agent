# Copy to .env and fill in. .env is gitignored.

# LLM for the skills (onboarding enrichment, planning, concierge reasoning)
OPENAI_API_KEY=
# gpt-5.6-terra | gpt-5.6-sol | gpt-5.6-luna — set in your local .env only
OPENAI_MODEL=gpt-5.6-terra
# Enable the OpenAI-backed Culture Concierge for live Director runs.
HERMES_LIVE_CULTURE=false

# Final delivery: Tour Guide narration -> ElevenLabs voice -> Telegram.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Mem0 — durable traveller taste (leave blank to use the in-memory stub)
MEM0_API_KEY=

# Linkup — live Local Scout search (leave blank to use the stub Scout)
LINKUP_API_KEY=

# Live tools (leave blank to use stubs)
FLIGHTS_API_KEY=
HOTELS_API_KEY=
MAPS_API_KEY=
WEATHER_API_KEY=
EVENTS_API_KEY=
