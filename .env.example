# Copy to .env and fill in. .env is gitignored.

# LLM for the skills (onboarding enrichment, planning, concierge reasoning)
OPENAI_API_KEY=
# gpt-5.6-sol | gpt-5.6-terra | gpt-5.6-luna
OPENAI_MODEL=gpt-5.6-terra
OPENAI_ONBOARDING_MODEL=gpt-5.6-terra
# Enable the OpenAI-backed Culture Concierge for live Director runs.
HERMES_LIVE_CULTURE=false

# Final delivery: Tour Guide narration -> ElevenLabs voice -> Telegram.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Telegram — Hermes bot + taste-swipe mini app
TELEGRAM_BOT_TOKEN=
# Allow initDataUnsafe fallback when WebApp initData string is empty (hackathon/dev)
TELEGRAM_ALLOW_UNSAFE_USER=true
# Public HTTPS URL for the mini app (local dev). On Railway/Render/Vercel this is auto-detected.
WEBAPP_URL=https://your-subdomain.ngrok-free.app
PORT=8787
# Production: use Telegram webhook instead of polling (required on serverless / recommended on Railway)
# Auto-enabled on Vercel (VERCEL=1). Set true manually for Railway/Render.
TELEGRAM_USE_WEBHOOK=false

# One-time deploy setup: GET /api/setup?secret=YOUR_SETUP_SECRET registers webhook + menu button
SETUP_SECRET=

# Google OAuth — Gmail + Calendar read (optional for connect flow)
# Redirect URI in Cloud Console: {WEBAPP_URL}/api/connect/google/callback
# Enable Gmail API + Google Calendar API in the same project
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Mem0 — durable traveller taste (leave blank to use the in-memory stub)
MEM0_API_KEY=

# Linkup — live Local Scout search (leave blank to use the stub Scout)
LINKUP_API_KEY=

# Live tools (leave blank to use stubs)
FLIGHTS_API_KEY=
HOTELS_API_KEY=
MAPS_API_KEY=
WEATHER_API_KEY=
EVENTS_API_KEY=
