# Copy to .env and fill in. .env is gitignored.

# LLM for the skills (onboarding enrichment, planning, concierge reasoning)
OPENAI_API_KEY=
# gpt-5.6-sol | gpt-5.6-terra | gpt-5.6-luna
OPENAI_MODEL=gpt-5.6-sol
OPENAI_ONBOARDING_MODEL=gpt-5.6-sol
# Enable the OpenAI-backed Culture Concierge for live Director runs.
HERMES_LIVE_CULTURE=false

# Telegram — Hermes bot + taste-swipe mini app
TELEGRAM_BOT_TOKEN=
# Allow initDataUnsafe fallback when WebApp initData string is empty (hackathon/dev)
TELEGRAM_ALLOW_UNSAFE_USER=true
# Public HTTPS URL for the mini app (ngrok: ngrok http 8787)
WEBAPP_URL=https://your-subdomain.ngrok-free.app
PORT=8787

# Google OAuth — Gmail + Calendar read (optional for connect flow)
# Redirect URI in Cloud Console: {WEBAPP_URL}/api/connect/google/callback
# Enable Gmail API + Google Calendar API in the same project
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Mem0 — durable traveller taste (leave blank to use the in-memory stub)
MEM0_API_KEY=

# Linkup — live Local Scout search (leave blank to use the stub Scout)
LINKUP_API_KEY=

# Live tools (leave blank to use stubs)
FLIGHTS_API_KEY=
HOTELS_API_KEY=
MAPS_API_KEY=
WEATHER_API_KEY=
EVENTS_API_KEY=
